[Unit]
Description=SpamLogger daemon for SpamTagger
After=mariadb@replica.service
Requires=mariadb@replica.service
PartOf=mailscanner.service spamtagger.target

[Service]
User=mailscanner
Group=spamtagger
PrivateTmp=false
Type=forking
ExecStart=/opt/spamtagger/bin/spamloggerdaemon.pl /opt/spamtagger/etc/spamlogger/spamlogger.conf

[Install]
WantedBy=spamtagger.target
